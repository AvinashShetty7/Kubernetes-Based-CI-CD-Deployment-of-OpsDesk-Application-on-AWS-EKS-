# Stage 1: Build React app
FROM node:20-alpine AS build

WORKDIR /app


COPY package*.json ./ 
RUN npm install

COPY . /app

# ARG VITE_API_URL=http://ae18c7b92d07d44aeb624ecbb08babd0-723a2d51d77928fb.elb.ap-south-1.amazonaws.com
# ENV VITE_API_URL=$VITE_API_URL

RUN npm run build

# Stage 2: Serve with nginx
FROM nginx:alpine

COPY --from=build  /app/dist/ /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"] 